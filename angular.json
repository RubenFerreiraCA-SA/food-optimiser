{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "meal-optimiser": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "frontend",
      "prefix": "app",
      "architect": {
          "build": {
            "builder": "@angular/build:application",
            "options": {
              "browser": "frontend/main.ts",
              "outputPath": "frontend/dist/meal-optimiser",
              "tsConfig": "tsconfig.app.json",
              "inlineStyleLanguage": "scss",
              "assets": [
              {
                "glob": "**/*",
                "input": "frontend/public"
              }
            ],
            "styles": [
              "frontend/styles.scss"
            ]
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "frontend/environments/environment.ts",
                  "with": "frontend/environments/environment.production.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "7kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "fileReplacements": [
                {
                  "replace": "frontend/environments/environment.ts",
                  "with": "frontend/environments/environment.development.ts"
                }
              ],
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "meal-optimiser:build:production"
            },
            "development": {
              "buildTarget": "meal-optimiser:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "progress": false,
            "reporters": ["dot"],
            "coverage": true,
            "coverageReporters": ["text-summary", "html"]
          }
        }
      }
    }
  }
}
