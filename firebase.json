{
  "hosting": {
    "public": "dist/meal-optimiser/browser",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "predeploy": [
      "pnpm build"
    ]
  }
}
